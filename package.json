{
  "name": "storyloom",
  "version": "1.1.0",
  "description": "Storyloom · 织叙 — 用一根时间线，把故事织成宇宙。面向小说作者、编剧与游戏叙事设计师的本地桌面创作工作台。",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:sidecar": "node scripts/start-sidecar.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:sidecar": "tsc -p tsconfig.server.json && npx pkg dist-server/server/sidecar-entry.js -o src-tauri/sidecars/storyloom-sidecar",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "pkg": {
    "scripts": [
      "dist-server/**/*.js"
    ],
    "assets": [
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
      "drizzle/**/*"
    ]
  },
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@gsap/react": "^2.1.2",
    "@icon-park/react": "^1.4.2",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/archiver": "^8.0.0",
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^6.0.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.18.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tdesign-icons-react": "^0.6.4",
    "tdesign-react": "^1.17.1",
    "uuid": "^11.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "nexe": "^5.0.0-beta.4",
    "pkg": "^5.8.1",
    "postcss": "^8.4.49",
    "postject": "^1.0.0-alpha.6",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0",
    "wait-on": "^9.0.10"
  }
}